archResults\n","\n","# создаем инструмент\n","search_tool = TavilySearchResults(\n","    tavily_api_key=TAVILY_API_KEY,\n","    max_results=3,\n","    include_answer=True,\n","    include_raw_content=True,\n","    # include_images=True,\n","    # search_depth=\"advanced\", # or \"basic\"\n","    include_domains=[\"github.io\"],\n","    # exclude_domains = []\n",")"],"metadata":{"id":"8JqR1-A41rRG"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# используем\n","search_tool.invoke({\"query\": \"что такое лазанья?\"})"],"metadata":{"id":"4cK68ltt2vuZ"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["# --- попробуем любой другой built-in инструмент ---\n","\n","\n"],"metadata":{"id":"AOjNcZaX251E"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["**кастомные**"],"metadata":{"id":"h3aNfI-lwrdy"}},{"cell_type":"code","source":["# --- кастомный инструмент для подсчета слов ---\n","\n","from langchain.tools import tool\n","\n","@tool\n","def word_count(text: str) -> str:\n","    \"\"\"Counts words in a given text. Use when you need to know the length of an article.\"\"\"\n","    return f\"Words: {len(text.split())}\""],"metadata":{"id":"U-_N2F0OuTRe"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["word_count.invoke({\"text\": \"нанотехнологии это круто\"})"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":35},"id":"RlPaDUa03C40","executionInfo":{"status":"ok","timestamp":1772208789542,"user_tz":-180,"elapsed":12,"user":{"displayName":"Catherine Kovalenko","userId":"14729822926829973326"}},"outputId":"450659cb-541b-4323-dc30-7fb69bc4371e"},"execution_count":null,"outputs":[{"output_type":"execute_result","data":{"text/plain":["'Words: 3'"],"application/vnd.google.colaboratory.intrinsic+json":{"type":"string"}},"metadata":{},"execution_count":23}]},{"cell_type":"code","source":["# --- любые другие инструменты под наши нужды ---\n","\n","\n"],"metadata":{"id":"6KDAu8Ds2_cx"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["## Реализовать логику агента, который разбивает сложный запрос пользователя на отдельные шаги и последовательно выполняет их"],"metadata":{"id":"zgq3C2NSp6Nu"}},{"cell_type":"markdown","source":["### пример smolagents"],"metadata":{"id":"DwvBPHZF_-xi"}},{"cell_type":"code","source":["from smolagents import CodeAgent, LiteLLMModel, WebSearchTool, VisitWebpageTool\n","\n","model = LiteLLMModel(\n","    model_id=\"groq/llama-3.1-8b-instant\",\n","    api_key=GROQ_API_KEY,\n","    temperature=0.7\n",")\n","\n","# все инструменты, которые будет использовать агент\n","tools = [\n","    WebSearchTool(),\n","    VisitWebpageTool(),\n","    word_count, # наш кастомный\n","]\n","\n","agent = CodeAgent(\n","    tools=tools,\n","    model=model,\n","    max_steps=10,\n","    verbosity_level=1\n",")"],"metadata":{"id":"PtfGL5wa462k"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["query = (\n","    \"\"\"\n","    Найди в интернете сайт про нанотехнологии. Открой его. Найди последнюю запись.\n","    Посчитай число слов. Как только получишь число слов — сразу верни финальный ответ\n","    \"\"\"\n",")\n","\n","print(f\"Запрос: {query}\")\n","print(\"-\" * 60)\n","\n","result = agent.run(query)\n","\n","print(\"-\" * 60)\n","print(\"Итоговый ответ агента:\")\n","print(result)"],"metadata":{"id":"Psz30GueqJDn"},"execution_count":null,"outputs":[]},{"cell_type":"markdown","source":["### пример langgraph"],"metadata":{"id":"TnrRNKoSAeFF"}},{"cell_type":"code","source":["from langgraph.graph import StateGraph, END\n","from typing import TypedDict, List\n","from langchain_groq import ChatGroq\n","from langchain_core.prompts import PromptTemplate\n","\n","from langchain_community.tools.tavily_search import TavilySearchResults\n","from langchain.tools import tool\n","\n","# инициализация Groq\n","llm = ChatGroq(\n","    model=\"llama-3.1-8b-instant\",\n","    temperature=0.7,\n","    groq_api_key=GROQ_API_KEY\n",")\n","\n","# инструменты (см. выше)\n","search_tool = search_tool\n","word_count_tool = word_count\n","\n","# определение состояния\n","class AgentState(TypedDict):\n","    messages: List[str]\n","    current_task: str\n","    search_results: str\n","    result: str\n","\n","# создание узлов графа\n","\n","# узел 1: LLM формирует запрос\n","def prepare_query_node(state: AgentState):\n","    prompt = PromptTemplate.from_template(\n","        \"\"\"\n","        Сформулируй поисковый запрос для: {task}.\n","        Верни только запрос.\n","        \"\"\"\n","    )\n","    chain = prompt | llm\n","    query = chain.invoke({\"task\": state[\"current_task\"]}).content.strip()\n","\n","    return {\n","        \"messages\": state[\"messages\"] + [f\"Query: {query}\"],\n","        \"current_task\": query  # перезаписываем задачу готовым запросом\n","    }\n","\n","# узел 2: поиск через Tavily\n","def search_node(state: AgentState):\n","    results = search_tool.invoke(state[\"current_task\"])\n","\n","    raw_text = \"\"\n","    url = \"\"\n","    for r in results:\n","        if r.get(\"raw_content\"):\n","            raw_text = r[\"raw_content\"]\n","            url = r.get(\"url\", \"\")\n","            break\n","\n","    return {\n","        \"messages\": state[\"messages\"] + [f\"URL: {url}\"],\n","        \"search_results\": raw_text\n","    }\n","\n","# узел 3: подсчёт слов  word_count\n","def count_node(state: AgentState):\n","    count = word_count.invoke(state[\"search_results\"])\n","\n","    return {\n","        \"messages\": state[\"messages\"] + [f\"Count: {count}\"],\n","        \"result\": count\n","    }\n","\n","# граф\n","workflow = StateGraph(AgentState)\n","workflow.add_node(\"prepare_query\", prepare_query_node)\n","workflow.add_node(\"search\", search_node)\n","workflow.add_node(\"count\", count_node)\n","\n","workflow.set_entry_point(\"prepare_query\")\n","workflow.add_edge(\"prepare_query\", \"search\")\n","workflow.add_edge(\"search\", \"count\")\n","workflow.add_edge(\"count\", END)\n","\n","app = workflow.compile()\n"],"metadata":{"id":"eutnKYVqAdhS"},"execution_count":null,"outputs":[]},{"cell_type":"code","source":["result = app.invoke({\n","    \"messages\": [],\n","    \"current_task\": \"найди статью про нанотехнологии и посчитай в ней число слов\",\n","    \"search_results\": \"\",\n","    \"result\": \"\"\n","})\n","\n","print(\"Шаги:\")\n","for msg in result[\"messages\"]:\n","    print(\" -\", msg)\n","print(\"~\" * 50)\n","print(result[\"result\"])"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"uI-BCtzWIrjC","executionInfo":{"status":"ok","timestamp":1772214285064,"user_tz":-180,"elapsed":5776,"user":{"displayName":"Catherine Kovalenko","userId":"14729822926829973326"}},"outputId":"55e3bb48-a0f7-4d55-8c88-e77670011e04"},"execution_count":null,"outputs":[{"output_type":"stream","name":"stdout","text":["Шаги:\n"," - Query: \"нанотехнологии и анализ количества слов в статье\"\n"," - URL: https://emiia.github.io/1/Criminology.pdf\n"," - Count: Words: 111882\n","~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~\n","Words: 111882\n"]}]},{"cell_type":"markdown","source":["### 4. Протестировать своего агента на нескольких многошаговых запросах"],"metadata":{"id":"Z3SNWB2sqEUQ"}},{"cell_type":"markdown","source":["\n","\n","---\n","\n"],"metadata":{"id":"ZeeGt6yo8j1d"}},{"cell_type":"markdown","source":["# Критерии оценивания"],"metadata":{"id":"F6ADsGSt8kvi"}},{"cell_type":"markdown","source":["Работа проверяется по следующим критериям (максимум 7 баллов):\n","\n","### Подбор инструментов (1 балл)\n","- [ ] 0.5 балла: определен тип задач, выполняемых агентом\n","- [ ] 0.5 балла: определен список инструментов\n","\n","### Инструменты smolagents (1 балл)\n","- [ ] 0.5 балла: опробован хотя бы один подходящий built-in инструмент\n","- [ ] 0.5 балла: создан хотя бы один подходящий кастомный инструмент\n","\n","### Ингструменты langgraph (1 балл)\n","- [ ] 0.5 балла: опробован хотя бы один подходящий built-in инструмент\n","- [ ] 0.5 балла: создан хотя бы один подходящий кастомный инструмент\n","\n","### Реализация логики агента (2 балла)\n","- [ ] 0.5 балла: агент работает как минимум с тремя инструментами\n","- [ ] 0.5 балла: среди инструментов есть и built-in, и кастомные\n","- [ ] 0.5 балла: есть пояснение выбора между smolagents и langgraph в контексте определенного набора задач\n","\n","- [ ] 0.5 балла: ДЛЯ SMOLAGENTS обоснована настройка max_steps, verbosity_level\n","- [ ] 0.5 балла: ДЛЯ LANGGRAPH обоснована выбранная структура графа\n","\n","### Тестирование и анализ (2 балла)\n","- [ ] 0.5 балла: агент протестирован минимум на трех многошаговых запросов\n","- [ ] 0.5 балла: агент разбивает запрос на шаги\n","- [ ] 0.5 балла: агент выполняет шаги последовательно, полностью\n","- [ ] 0.5 балла: проанализирована не/успешность выполнения задач\n"],"metadata":{"id":"W8DzHEVq8nYG"}}]}